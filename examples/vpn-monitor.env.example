# Copy this file to /etc/vpn-monitor.env or another secure location.
# Do not commit the real env file.

MONITOR_USERNAME=monitor
# sha256 of the login password.
MONITOR_PASSWORD_SHA256=replace-with-sha256
MONITOR_SESSION_SECRET=replace-with-random-secret

MONITOR_HOST=127.0.0.1
MONITOR_PORT=9100
MONITOR_DB=/home/windows_control/monitor-panel/monitor.db
XRAY_ACCESS_LOG=/var/lib/marzban/xray_access.log
MONITOR_RETENTION_DAYS=30
MONITOR_POLL_SECONDS=1.5
MONITOR_ACTIVE_WINDOW_SECONDS=600
MONITOR_COOKIE_PATH=/monitor
MONITOR_COLLECTOR_ENABLED=true
